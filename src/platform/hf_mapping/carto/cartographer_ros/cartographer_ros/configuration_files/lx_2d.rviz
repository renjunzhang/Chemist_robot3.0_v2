        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Scale: 111.43245697021484
      Target Frame: <Fixed Frame>
      X: -1.2083148956298828
      Y: 1.1801824569702148
