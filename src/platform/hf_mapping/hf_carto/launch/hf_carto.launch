<launch>
    <param name="/use_sim_time" value="false" />

    <!--    是否重定位-->
    <param name="localization" type="bool" value="false" />

    <node name="cartographer_node" pkg="cartographer_ros"
        type="cartographer_node"
        args="
          -configuration_directory $(find hf_carto)/config
          -configuration_basename hf_carto.lua"
        output="screen">
        <remap from="scan" to="/scan_full_filtered" />
        <remap from="odom" to="/odom" />

    </node>

    <node name="cartographer_occupancy_grid_node" pkg="cartographer_ros"
        type="cartographer_occupancy_grid_node" args="-resolution 0.02" />

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find hf_carto)/launch/hf_carto.rviz" />

</launch>