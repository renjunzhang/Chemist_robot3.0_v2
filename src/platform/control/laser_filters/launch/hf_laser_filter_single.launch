<launch>
    <arg name="robot_name" default="hf_0" />

    <node pkg="laser_filters" type="scan_to_scan_filter_chain" output="screen"
        name="laser_filter_node">
        <remap from="scan" to="/scan_full" />
        <remap from="scan_filtered" to="/scan_full_filtered" />
        <rosparam command="load" file="$(find laser_filters)/launch/$(arg robot_name)/hf_laser_filter.yaml" />
    </node>
</launch>