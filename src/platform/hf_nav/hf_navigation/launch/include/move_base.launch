<launch>

    <arg name="cmd_vel_topic" default="/hf_platform/nav_vel" />

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen"
        clear_params="true">

        <rosparam file="$(find hf_navigation)/params/costmap_common_params.yaml" command="load"
            ns="global_costmap" />
        <rosparam file="$(find hf_navigation)/params/costmap_common_params.yaml" command="load"
            ns="local_costmap" />

        <rosparam file="$(find hf_navigation)/params/map_nav_params/local_costmap_params.yaml"
            command="load" />
        <rosparam file="$(find hf_navigation)/params/map_nav_params/global_costmap_params.yaml"
            command="load" />

        <rosparam file="$(find hf_navigation)/params/move_base_params.yaml" command="load" />

        <rosparam file="$(find hf_navigation)/params/local_planner/eband_local_planner_params.yaml"
            command="load" />

        <!-- <param name="base_global_planner" type="string" value="navfn/NavfnROS" /> -->
        <param name="base_global_planner" type="string" value="global_planner/GlobalPlanner" />
        <param name="base_local_planner" value="eband_local_planner/EBandPlannerROS" />

        <remap from="cmd_vel" to="$(arg cmd_vel_topic)" />
        <remap from="odom" to="/odom" />
    </node>

</launch>